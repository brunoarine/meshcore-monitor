    {
      "id": 1,
      "type": "stat",
      "title": "Battery",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "decimals": 2,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 3.6},
              {"color": "green", "value": 3.8}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "refId": "A",
          "query": "SELECT last(\"bat\") / 1000 AS \"battery\" FROM \"meshcore_status\" WHERE (\"node\" =~ /^$node$/) AND $timeFilter GROUP BY \"node\"",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ]
    },
